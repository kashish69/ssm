# pi_agent config — copy to pi_agent/.env (or /etc/pi-agent/pi-agent.env), fill in, chmod 600.
# Consumed by pi_agent.py via os.environ (systemd: EnvironmentFile).
#
# One-time system setup this .env can't cover — passwordless sudo for the
# nmcli calls the WiFi loop makes (it runs non-interactively, so without this
# every attempt fails with "sudo: a password is required"):
#   sudo visudo -f /etc/sudoers.d/pi-agent-nmcli
#   # add: pi ALL=(root) NOPASSWD: /usr/bin/nmcli device wifi rescan, /usr/bin/nmcli connection delete *, /usr/bin/nmcli device wifi connect *

# --- MQTT broker (over WebSocket / WSS through Caddy) ---
# Public server domain (SAME host as BACKEND_UPLOAD_URL below) on HTTPS 443.
# Caddy reverse-proxies the /mqtt path to mosquitto's websockets listener and
# terminates TLS; the agent connects wss://<domain>:443<MQTT_WS_PATH>.
MQTT_BROKER_HOST=ssm.example.com
MQTT_BROKER_PORT=443
MQTT_WS_PATH=/mqtt
# CA cert path — only needed if the broker uses a self-signed/private CA.
# Leave commented when Caddy serves a public (e.g. Let's Encrypt) cert.
# MQTT_TLS_CA_CERT=/etc/pi-agent/ca.crt

# --- Device identity (required) ---
DEVICE_ID=front-porch
DEVICE_API_KEY=change-me-same-key-seeded-in-backend-DEVICE_SEEDS

# --- Backend upload endpoint (required) ---
BACKEND_UPLOAD_URL=https://example.com/api/devices/front-porch/upload

# --- WiFi auto-connect defaults (optional; overridable via MQTT wifi_config) ---
WIFI_SSID=MyPhoneHotspot
WIFI_PASSWORD=change-me
# Optional: priority-ordered list of known networks to try instead of the
# single WIFI_SSID/WIFI_PASSWORD above — "ssid:pw;ssid:pw;...". Tried in
# order (first entry preferred); advances to the next after WIFI_MAX_ATTEMPTS
# failures on the current one. Leave unset to just use WIFI_SSID/WIFI_PASSWORD.
# WIFI_CANDIDATES=WIFI-J3SNSU:deploysitepassword;test:testpassword
# The agent runs as a non-root user, so this directory must be writable by it:
#   sudo mkdir -p /etc/pi-agent && sudo chown $USER /etc/pi-agent
# (or point this at a path under the user's home).
WIFI_OVERRIDE_FILE=/etc/pi-agent/wifi_override.json
WIFI_SCAN_INTERVAL=2
# Failed attempts on a network pushed from the UI (or a WIFI_CANDIDATES entry)
# before the agent gives up — reverting to the last known-good SSID for a UI
# push, or advancing to the next candidate for WIFI_CANDIDATES.
WIFI_MAX_ATTEMPTS=3

# --- Logging (optional) ---
LOG_FILE=/home/pi/pi_agent.log
